@page "/{AppRoute}"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HttpClient Http
@inject KlooieBlazorAppRegistry Registry

@if (registration is null)
{
    <main class="home-page">
        <section class="home-panel">
            <h1>App not found</h1>
            <p>No app is registered at /@AppRoute.</p>
            <a href="">Back to apps</a>
        </section>
    </main>
}
else
{
    <PageTitle>@registration.BrowserMetadata.BrowserTitle</PageTitle>
    <HeadContent>
        <meta name="application-name" content="@registration.BrowserMetadata.PwaName" />
        <meta name="apple-mobile-web-app-title" content="@registration.BrowserMetadata.PwaShortName" />
        <meta name="description" content="@registration.BrowserMetadata.Description" />
        <meta name="theme-color" content="@registration.BrowserMetadata.ThemeColor" />
        @if (registration.BrowserMetadata.FaviconPath is not null)
        {
            <link rel="icon" href="@registration.BrowserMetadata.FaviconPath" />
            <link rel="shortcut icon" href="@registration.BrowserMetadata.FaviconPath" />
        }
        @if (registration.BrowserMetadata.AppIconPath is not null)
        {
            <link rel="apple-touch-icon" href="@registration.BrowserMetadata.AppIconPath" />
        }
    </HeadContent>
    <div @ref="hostElement" class="klooie-host" data-ticks="@tickCount" tabindex="0">
        <canvas class="klooie-canvas" aria-label="@registration.DisplayName"></canvas>
    </div>
}

@code {
    private BrowserKlooieRuntime? runtime;
    private KlooieBlazorAppRegistration? registration;
    private DotNetObjectReference<KlooieAppHost>? dotNetRef;
    private ElementReference hostElement;
    private int? pumpId;
    private long tickCount;
    private string? activeRoute;

    [Parameter]
    public string? AppRoute { get; set; }

    [JSInvokable]
    public BrowserConsoleFrame Tick(int width, int height, double elapsedMilliseconds, BrowserKeyboardEvent[] keyboardEvents, string? gamepadSnapshotJson, bool mobileExperience)
    {
        foreach (var keyboardEvent in keyboardEvents)
        {
            SendKey(keyboardEvent);
        }

        tickCount++;
        var budget = TimeSpan.FromMilliseconds(Math.Clamp(elapsedMilliseconds, 1, 33));
        return runtime?.Tick(width, height, budget, gamepadSnapshotJson, mobileExperience) ?? BrowserConsoleFrame.Empty;
    }

    [JSInvokable]
    public void SendKey(BrowserKeyboardEvent keyboardEvent)
    {
        var keyInfo = BrowserConsoleKeyMapper.ToConsoleKeyInfo(keyboardEvent);
        if (keyInfo is null) return;
        runtime?.EnqueueKey(keyInfo.Value);
    }

    protected override void OnParametersSet()
    {
        registration = AppRoute is null ? null : Registry.Find(AppRoute);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (registration is null) return;
        if (runtime is not null && activeRoute == registration.Route) return;

        await StopPumpAsync();
        runtime?.Dispose();

        activeRoute = registration.Route;
        runtime = new BrowserKlooieRuntime(registration, JS, Http);
        dotNetRef = DotNetObjectReference.Create(this);
        pumpId = await JS.InvokeAsync<int>("klooieFramePump.start", dotNetRef, hostElement, registration.MobileOptions);
    }

    public async ValueTask DisposeAsync()
    {
        await StopPumpAsync();
        runtime?.Dispose();
    }

    private async Task StopPumpAsync()
    {
        if (pumpId is not null)
        {
            await JS.InvokeVoidAsync("klooieFramePump.stop", pumpId.Value);
            pumpId = null;
        }

        dotNetRef?.Dispose();
        dotNetRef = null;
    }
}
