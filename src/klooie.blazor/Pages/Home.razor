@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<h1>klooie browser renderer</h1>

<p>Live klooie visual tree rendered from <code>LayoutRoot.Bitmap</code>.</p>

<div class="browser-demo" data-ticks="@tickCount">
    <BrowserConsoleRenderer Bitmap="runtime.Bitmap" />
</div>

@code {
    private readonly BrowserKlooieRuntime runtime = new();
    private DotNetObjectReference<Home>? dotNetRef;
    private int? pumpId;
    private long tickCount;

    [JSInvokable]
    public Task Tick()
    {
        tickCount++;
        runtime.Tick(TimeSpan.FromMilliseconds(8));
        return InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        dotNetRef = DotNetObjectReference.Create(this);
        pumpId = await JS.InvokeAsync<int>("klooieFramePump.start", dotNetRef);
    }

    public async ValueTask DisposeAsync()
    {
        if (pumpId is not null) await JS.InvokeVoidAsync("klooieFramePump.stop", pumpId.Value);

        dotNetRef?.Dispose();
        runtime.Dispose();
    }
}
