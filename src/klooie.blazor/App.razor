@implements IAsyncDisposable
@inject IJSRuntime JS

<div @ref="hostElement" class="klooie-host" data-ticks="@tickCount">
    <BrowserConsoleRenderer Bitmap="runtime.Bitmap" />
</div>

@code {
    private readonly BrowserKlooieRuntime runtime = new();
    private DotNetObjectReference<App>? dotNetRef;
    private ElementReference hostElement;
    private int? pumpId;
    private long tickCount;

    [JSInvokable]
    public void Tick(int width, int height)
    {
        tickCount++;
        runtime.Tick(width, height, TimeSpan.FromMilliseconds(8));
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        dotNetRef = DotNetObjectReference.Create(this);
        pumpId = await JS.InvokeAsync<int>("klooieFramePump.start", dotNetRef, hostElement);
    }

    public async ValueTask DisposeAsync()
    {
        if (pumpId is not null) await JS.InvokeVoidAsync("klooieFramePump.stop", pumpId.Value);

        dotNetRef?.Dispose();
        runtime.Dispose();
    }
}
