@namespace klooie.blazor.BrowserConsole

<div class="browser-console" style="@GridStyle" role="img" aria-label="klooie console bitmap">
    @foreach (var row in Bitmap.Rows)
    {
        <div class="browser-console-row">
            @foreach (var run in row.Runs)
            {
                <span class="browser-console-run" style="@GetRunStyle(run)">@run.Text</span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required BrowserConsoleBitmap Bitmap { get; set; }

    private string GridStyle => $"--browser-console-bitmap-width: {Bitmap.Width}; grid-template-rows: repeat({Bitmap.Height}, var(--browser-console-cell-height));";

    private static string GetRunStyle(BrowserConsoleRun run) => $"width: calc({run.Length} * var(--browser-console-cell-width)); color: {run.ForegroundColor}; background-color: {run.BackgroundColor};";
}
